     -->

    


    <!-- http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#affectedDeviceType -->

    <owl:ObjectProperty rdf:about="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#affectedDeviceType">
        <rdfs:domain rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Risk"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#DeviceType"/>
        <rdfs:comment xml:lang="en">Indicates which type of device is affected by the risk.</rdfs:comment>
        <rdfs:label xml:lang="en">affectedDeviceType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#countryReported -->

    <owl:ObjectProperty rdf:about="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#countryReported">
        <rdfs:domain rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Incident"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasRisk"/>
                <owl:someValuesFrom rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Risk"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Country"/>
        <rdfs:comment xml:lang="en">Shows the country where the incident was reported.</rdfs:comment>
        <rdfs:label xml:lang="en">countryReported</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasActionType -->

    <owl:ObjectProperty rdf:about="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasActionType">
        <rdfs:domain rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#ActionType"/>
        <rdfs:comment xml:lang="en">Specifies the kind of corrective action that was taken.</rdfs:comment>
        <rdfs:label xml:lang="en">hasActionType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasCompetentAuthority -->

    <owl:ObjectProperty rdf:about="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasCompetentAuthority">
        <rdfs:domain rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#CompetentAuthority"/>
        <rdfs:comment xml:lang="en">Links a manufacturer to the authority responsible for its regulatory oversight.</rdfs:comment>
        <rdfs:label xml:lang="en">hasCompetentAuthority</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasCorrectiveAction -->

    <owl:ObjectProperty rdf:about="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasCorrectiveAction">
        <rdfs:domain rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Incident"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasRisk"/>
                <owl:someValuesFrom rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Risk"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#CorrectiveAction"/>
        <rdfs:comment xml:lang="en">Connects an incident with the safety action taken in response.</rdfs:comment>
        <rdfs:label xml:lang="en">hasCorrectiveAction</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasDeviceType -->

    <owl:ObjectProperty rdf:about="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasDeviceType">
        <rdfs:domain rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Device"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasManufacturer"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Manufacturer"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#DeviceType"/>
        <rdfs:comment xml:lang="en">Assigns a device to its device type category.</rdfs:comment>
        <rdfs:label xml:lang="en">hasDeviceType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasIncident -->

    <owl:ObjectProperty rdf:about="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasIncident">
        <rdfs:domain rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Device"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasManufacturer"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Manufacturer"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Incident"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasRisk"/>
                <owl:someValuesFrom rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Risk"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Links a device to an incident that has been reported for it.</rdfs:comment>
        <rdfs:label xml:lang="en">hasIncident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasIncidentType -->

    <owl:ObjectProperty rdf:about="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasIncidentType">
        <rdfs:domain rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Incident"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasRisk"/>
                <owl:someValuesFrom rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Risk"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#IncidentType"/>
        <rdfs:comment xml:lang="en">Assigns an incident to its incident type.</rdfs:comment>
        <rdfs:label xml:lang="en">hasIncidentType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasManufacturer -->

    <owl:ObjectProperty rdf:about="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasManufacturer">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Device"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasManufacturer"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Manufacturer"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Manufacturer"/>
        <rdfs:comment xml:lang="en">Connects a device with the company that manufactures it.</rdfs:comment>
        <rdfs:label xml:lang="en">hasManufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasProbability -->

    <owl:ObjectProperty rdf:about="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasProbability">
        <rdfs:domain rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Risk"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Probability"/>
        <rdfs:comment xml:lang="en">Indicates how likely the risk is to occur.</rdfs:comment>
        <rdfs:label xml:lang="en">hasProbability</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasRegulatoryFramework -->

    <owl:ObjectProperty rdf:about="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasRegulatoryFramework">
        <rdfs:domain rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Device"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasManufacturer"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Manufacturer"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#RegulatoryFramework"/>
        <rdfs:comment xml:lang="en">States which regulatory framework applies to the device.</rdfs:comment>
        <rdfs:label xml:lang="en">hasRegulatoryFramework</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasRisk -->

    <owl:ObjectProperty rdf:about="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasRisk">
        <rdfs:domain rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Incident"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasRisk"/>
                <owl:someValuesFrom rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Risk"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Risk"/>
        <rdfs:comment xml:lang="en">Relates an incident to the risk identified in that case.</rdfs:comment>
        <rdfs:label xml:lang="en">hasRisk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasRiskCategory -->

    <owl:ObjectProperty rdf:about="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasRiskCategory">
        <rdfs:domain rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Risk"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#RiskCategory"/>
        <rdfs:comment xml:lang="en">Places a risk under a broader risk category.</rdfs:comment>
        <rdfs:label xml:lang="en">hasRiskCategory</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasRiskClass -->

    <owl:ObjectProperty rdf:about="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasRiskClass">
        <rdfs:domain rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Device"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasManufacturer"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Manufacturer"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#RiskClass"/>
        <rdfs:comment xml:lang="en">Associates a device with its regulatory risk class.</rdfs:comment>
        <rdfs:label xml:lang="en">hasRiskClass</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasRiskType -->

    <owl:ObjectProperty rdf:about="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasRiskType">
        <rdfs:domain rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Risk"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#RiskType"/>
        <rdfs:comment xml:lang="en">Specifies the kind of risk involved.</rdfs:comment>
        <rdfs:label xml:lang="en">hasRiskType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasSeverity -->

    <owl:ObjectProperty rdf:about="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasSeverity">
        <rdfs:domain rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Risk"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Severity"/>
        <rdfs:comment xml:lang="en">Shows how serious the risk may be.</rdfs:comment>
        <rdfs:label xml:lang="en">hasSeverity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasStatus -->

    <owl:ObjectProperty rdf:about="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasStatus">
        <rdfs:domain rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Status"/>
        <rdfs:comment xml:lang="en">Shows the current status of a corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">hasStatus</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#locatedInCountry -->

    <owl:ObjectProperty rdf:about="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#locatedInCountry">
        <rdfs:domain rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Country"/>
        <rdfs:comment xml:lang="en">Shows the country where a manufacturer is based.</rdfs:comment>
        <rdfs:label xml:lang="en">locatedInCountry</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#reportingEntity -->

    <owl:ObjectProperty rdf:about="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#reportingEntity">
        <rdfs:domain rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Incident"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#hasRisk"/>
                <owl:someValuesFrom rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Risk"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Manufacturer"/>
        <rdfs:comment xml:lang="en">Indicates which organisation reported the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">reportingEntity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#action_date -->

    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#action_date">
        <rdfs:domain rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Stores the date on which the corrective action was launched.</rdfs:comment>
        <rdfs:label xml:lang="en">action_date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#authorization_number -->

    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#authorization_number">
        <rdfs:domain rdf:resource="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the regulatory authorisation number linked to the manufacturer.</rdfs:comment>
