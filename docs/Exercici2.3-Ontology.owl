    <DLSafeRule>
        <Annotation>
            <AnnotationProperty IRI="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
            <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#boolean">true</Literal>
        </Annotation>
        <Annotation>
            <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
            <Literal>Infers that corrective action has been taken for an incident when the linked corrective action has closed status</Literal>
        </Annotation>
        <Annotation>
            <AnnotationProperty abbreviatedIRI="rdfs:label"/>
            <Literal>Rule2</Literal>
        </Annotation>
        <Body>
            <ClassAtom>
                <Class IRI="#Incident"/>
                <Variable IRI="#i"/>
            </ClassAtom>
            <ObjectPropertyAtom>
                <ObjectProperty IRI="#hasCorrectiveAction"/>
                <Variable IRI="#i"/>
                <Variable IRI="#a"/>
            </ObjectPropertyAtom>
            <ObjectPropertyAtom>
                <ObjectProperty IRI="#hasStatus"/>
                <Variable IRI="#a"/>
                <Variable IRI="#s"/>
            </ObjectPropertyAtom>
            <ClassAtom>
                <Class IRI="#Closed"/>
                <Variable IRI="#s"/>
            </ClassAtom>
        </Body>
        <Head>
            <DataPropertyAtom>
                <DataProperty IRI="#corrective_action_taken"/>
                <Variable IRI="#i"/>
                <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#boolean">true</Literal>
            </DataPropertyAtom>
        </Head>
    </DLSafeRule>
    <DLSafeRule>
        <Annotation>
            <AnnotationProperty IRI="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
            <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#boolean">true</Literal>
        </Annotation>
        <Annotation>
            <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
            <Literal>Infers that a device is an in vitro diagnostic device when it is regulated under the IVDR framework</Literal>
        </Annotation>
        <Annotation>
            <AnnotationProperty abbreviatedIRI="rdfs:label"/>
            <Literal>Rule1</Literal>
        </Annotation>
        <Body>
            <ClassAtom>
                <Class IRI="#Device"/>
                <Variable IRI="#d"/>
            </ClassAtom>
            <ObjectPropertyAtom>
                <ObjectProperty IRI="#hasRegulatoryFramework"/>
                <Variable IRI="#d"/>
                <Variable IRI="#rf"/>
            </ObjectPropertyAtom>
            <ClassAtom>
                <Class IRI="#IVDR"/>
                <Variable IRI="#rf"/>
            </ClassAtom>
        </Body>
        <Head>
            <ClassAtom>
                <Class IRI="#InVitroDiagnosticDevice"/>
                <Variable IRI="#d"/>
            </ClassAtom>
        </Head>
    </DLSafeRule>
    <DLSafeRule>
        <Annotation>
            <AnnotationProperty IRI="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
            <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#boolean">true</Literal>
        </Annotation>
        <Annotation>
            <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
            <Literal>Infers that a risk belongs to the device failure category when its risk type is malfunction risk</Literal>
        </Annotation>
        <Annotation>
            <AnnotationProperty abbreviatedIRI="rdfs:label"/>
            <Literal>Rule3</Literal>
        </Annotation>
        <Body>
            <ClassAtom>
                <Class IRI="#Risk"/>
                <Variable IRI="#r"/>
            </ClassAtom>
            <ObjectPropertyAtom>
                <ObjectProperty IRI="#hasRiskType"/>
                <Variable IRI="#r"/>
                <Variable IRI="#t"/>
            </ObjectPropertyAtom>
            <ClassAtom>
                <Class IRI="#MalfunctionRisk"/>
                <Variable IRI="#t"/>
            </ClassAtom>
        </Body>
        <Head>
            <ClassAtom>
                <Class IRI="#DeviceFailure"/>
                <Variable IRI="#r"/>
            </ClassAtom>
        </Head>
    </DLSafeRule>
