<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu#"
     xml:base="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:dbpedia="http://dbpedia.org/resource/"
     xmlns:dcterms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://www.uoc.edu/def/OntologiaDeDispositiusMedicsRegulatsPelMarcEuropeu">
        <dcterms:creator xml:lang="en">Regie Marasigan</dcterms:creator>
        <dcterms:description xml:lang="en">The ontology of medical devices regulated under the European MDR/IVDR framework is designed to structure and represent information about medical devices, especially high-risk devices and in vitro diagnostic devices. This ontology models the relationship between the main elements of the domain: the devices, the manufacturers, the identified risks, the safety corrective actions, and the reported incidents. This makes it possible to keep all the information organized in one place, making it more accessible and useful for everyone.</dcterms:description>
        <dcterms:title xml:lang="en">Ontology of Medical Devices Regulated under the European MDR/IVDR Framework</dcterms:title>
    </owl:Ontology>
    


